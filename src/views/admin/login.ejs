<div class="card small">
  <h2>Login Admin</h2>

  <% if (errors.geral) { %>
    <p class="error"><%= errors.geral %></p>
  <% } %>

  <form method="post" class="form">
    <div class="form-group">
      <label>Login</label>
      <input type="text" name="login" value="<%= form.login || '' %>" autocomplete="username" />
      <% if (errors.login) { %><span class="error"><%= errors.login %></span><% } %>
    </div>

    <div class="form-group">
      <label>Senha</label>
      <input type="password" name="senha" autocomplete="current-password" />
      <% if (errors.senha) { %><span class="error"><%= errors.senha %></span><% } %>
    </div>

    <button class="btn" type="submit">Entrar</button>
  </form>
</div>
