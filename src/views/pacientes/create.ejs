<div class="card">
  <h2><%= editing ? 'Editar Paciente' : 'Cadastrar Paciente' %></h2>

  <% if (errors.geral) { %>
    <p class="error"><%= errors.geral %></p>
  <% } %>

  <form method="post" class="form">
    <div class="form-group">
      <label>Nome*</label>
      <input type="text" name="nome" value="<%= form.nome || '' %>" />
      <% if (errors.nome) { %><span class="error"><%= errors.nome %></span><% } %>
    </div>

    <div class="form-group">
      <label>CPF</label>
      <input type="text" name="cpf" value="<%= form.cpf || '' %>" />
    </div>

    <div class="form-group">
      <label>Data de Nascimento</label>
      <input
  type="date"
  name="dataNascimento"
  value="<%= form.dataNascimento ? String(form.dataNascimento).substring(0,10) : '' %>"
/>

    </div>

    <div class="form-group">
      <label>Telefone</label>
      <input type="text" name="telefone" value="<%= form.telefone || '' %>" />
    </div>

    <div class="form-group">
      <label>Endereço</label>
      <input type="text" name="endereco" value="<%= form.endereco || '' %>" />
    </div>

    <div class="form-group">
      <label>Email</label>
      <input type="email" name="email" value="<%= form.email || '' %>" />
    </div>

    <button class="btn" type="submit"><%= editing ? 'Salvar alterações' : 'Cadastrar' %></button>
    <a href="/pacientes" class="btn outline">Cancelar</a>
  </form>
</div>
