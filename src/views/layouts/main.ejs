<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title || 'Clínica Médica' %></title>

  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css" />
</head>
<body>
  <header class="topbar">
    <div class="container topbar-inner">
      <div class="brand">
        <span class="brand-logo">+</span>
        <div class="brand-text">
          <span class="brand-title">Clínica Médica</span>
          <span class="brand-subtitle">Sistema de Consultas</span>
        </div>
      </div>

      <button class="nav-toggle" aria-label="Abrir menu" onclick="document.body.classList.toggle('nav-open')">
        Menu
      </button>

      <nav class="nav-links">
        <a href="/" class="<%= (typeof active !== 'undefined' && active === 'home') ? 'active' : '' %>">
          Início
        </a>

        <% if (admin) { %>
          <a href="/pacientes" class="<%= (typeof active !== 'undefined' && active === 'pacientes') ? 'active' : '' %>">
            Pacientes
          </a>
          <a href="/medicos" class="<%= (typeof active !== 'undefined' && active === 'medicos') ? 'active' : '' %>">
            Médicos
          </a>
          <a href="/consultas" class="<%= (typeof active !== 'undefined' && active === 'consultas') ? 'active' : '' %>">
            Consultas
          </a>
        <% } %>

        <a href="<%= admin ? '/admin/dashboard' : '/admin/login' %>"
           class="<%= (typeof active !== 'undefined' && active === 'admin') ? 'active' : '' %>">
          Admin
        </a>
      </nav>

      <% if (admin) { %>
        <a href="/admin/logout" class="logout-icon" title="Sair">Sair</a>
      <% } %>
    </div>
  </header>

  <main class="container main-content">
    <%- body %>
  </main>

  <footer class="footer">
    <div class="container">
      <small>&copy; 2026 - Clínica Médica</small>
    </div>
  </footer>
</body>
</html>
