<div class="card">
  <h2><%= editing ? 'Editar Médico' : 'Cadastrar Médico' %></h2>

  <% if (errors.geral) { %>
    <p class="error"><%= errors.geral %></p>
  <% } %>

  <form method="post" class="form">
    <div class="form-group">
      <label>Nome*</label>
      <input type="text" name="nome" value="<%= form.nome || '' %>" />
      <% if (errors.nome) { %><span class="error"><%= errors.nome %></span><% } %>
    </div>

    <div class="form-group">
      <label>CRM*</label>
      <input type="text" name="crm" value="<%= form.crm || '' %>" />
      <% if (errors.crm) { %><span class="error"><%= errors.crm %></span><% } %>
    </div>

    <div class="form-group">
      <label>Especialidade*</label>
      <input type="text" name="especialidade" value="<%= form.especialidade || '' %>" />
      <% if (errors.especialidade) { %><span class="error"><%= errors.especialidade %></span><% } %>
    </div>

    <div class="form-group">
      <label>Telefone</label>
      <input type="text" name="telefone" value="<%= form.telefone || '' %>" />
    </div>

    <div class="form-group">
      <label>Email</label>
      <input type="email" name="email" value="<%= form.email || '' %>" />
    </div>

    <div class="form-group">
      <label>Disponibilidade</label>
      <input type="text" name="disponibilidade" value="<%= form.disponibilidade || '' %>" />
    </div>

    <button class="btn" type="submit"><%= editing ? 'Salvar alterações' : 'Cadastrar' %></button>
    <a href="/medicos" class="btn outline">Cancelar</a>
  </form>
</div>
