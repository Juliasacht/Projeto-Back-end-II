<div class="card">
  <h2>Cadastrar Médico</h2>
  <% if (errors.geral) { %>
    <p class="error"><%= errors.geral %></p>
  <% } %>
  <form method="post" action="/medicos/novo">
    <div class="row">
      <div>
        <label>Nome*</label>
        <input name="nome" value="<%= form.nome || '' %>"/>
        <% if (errors.nome) { %><div class="error"><%= errors.nome %></div><% } %>
      </div>
      <div>
        <label>CRM*</label>
        <input name="crm" value="<%= form.crm || '' %>"/>
        <% if (errors.crm) { %><div class="error"><%= errors.crm %></div><% } %>
      </div>
    </div>
    <div class="row">
      <div>
        <label>Especialidade*</label>
        <input name="especialidade" value="<%= form.especialidade || '' %>"/>
        <% if (errors.especialidade) { %><div class="error"><%= errors.especialidade %></div><% } %>
      </div>
      <div>
        <label>Telefone</label>
        <input name="telefone" value="<%= form.telefone || '' %>"/>
      </div>
    </div>
    <div class="row">
      <div>
        <label>Email</label>
        <input name="email" value="<%= form.email || '' %>"/>
      </div>
      <div>
        <label>Disponibilidade</label>
        <input name="disponibilidade" value="<%= form.disponibilidade || '' %>"/>
      </div>
    </div>
    <div style="margin-top:12px; display:flex; gap:8px">
      <button class="btn" type="submit">Salvar</button>
      <a class="btn outline" href="/medicos">Cancelar</a>
    </div>
  </form>
</div>
